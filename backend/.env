NODE_ENV=development
PORT=4001
APP_URL=http://localhost:4001
FRONTEND_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nexu_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 / MinIO Configuration
# Для локальной разработки с MinIO раскомментируйте:
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexu-images
AWS_ENDPOINT=http://localhost:9000

# Для production AWS S3 используйте:
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
# AWS_CDN_URL=https://your-cdn-domain.com (optional, for CloudFront or custom CDN)
# AWS_ENDPOINT не указывайте для AWS S3
