# /opt/nexu/backend.env на сервере — монтируется в контейнер backend

NODE_ENV=production
PORT=4000

# БД (host берётся из docker-compose.prod.yml)
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG
DB_NAME=deke_db

# Redis
REDIS_PORT=6379

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRES_IN=7d

# S3 / MinIO (если используется)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
